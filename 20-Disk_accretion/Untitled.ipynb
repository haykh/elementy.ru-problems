   "source": [
    "import astropy.units as u\n",
    "import astropy.constants as c\n",
    "import numpy as np\n",
    "\n",
    "M = 5 * u.Msun\n",
    "R = 10 * (2 * c.G * M / c.c**2)\n",
    "rho = 1e20 * c.m_p / u.cm**3\n",
    "Mdot = 1e17 * u.g / u.s\n",
    "HoverR = 1e-2\n",
    "vphi = np.sqrt(c.G * M / R)\n",
    "\n",
    "(Mdot / (rho * vphi * R**2 * HoverR**3)).cgs"
   ]
  },

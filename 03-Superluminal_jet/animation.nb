Cell[CellGroupData[{
Cell[BoxData[{
 RowBox[{"Clear", "[", "\"\<Global`*\>\"", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Theta]", "=", 
   RowBox[{"30", " ", 
    RowBox[{"Pi", "/", "180."}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"jet", "[", "t_", "]"}], ":=", 
  RowBox[{"Disk", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"0.9", 
       RowBox[{"Sin", "[", "\[Theta]", "]"}], "t"}], ",", 
      RowBox[{"10", "-", 
       RowBox[{"0.9", 
        RowBox[{"Cos", "[", "\[Theta]", "]"}], "t"}]}]}], "}"}], ",", "0.2"}],
    "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ray", "[", 
   RowBox[{"t0_", ",", "t_"}], "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{"LightOrange", ",", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"t", "\[LessEqual]", "t0"}], ",", 
      RowBox[{"Opacity", "[", "0", "]"}], ",", 
      RowBox[{"Opacity", "[", "1", "]"}]}], "]"}], ",", 
    RowBox[{"Disk", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"0.9", 
         RowBox[{"Sin", "[", "\[Theta]", "]"}], "t0"}], ",", 
        RowBox[{"Max", "[", 
         RowBox[{
          RowBox[{"10", "-", 
           RowBox[{"0.9", 
            RowBox[{"Cos", "[", "\[Theta]", "]"}], "t0"}], "-", 
           RowBox[{
            RowBox[{"Cos", "[", "\[Theta]", "]"}], 
            RowBox[{"(", 
             RowBox[{"t", "-", "t0"}], ")"}]}]}], ",", "0"}], "]"}]}], "}"}], 
      ",", "0.1"}], "]"}]}], "}"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"picture", "[", "t_", "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"Graphics", "[", 
   RowBox[{
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"ray", "[", 
         RowBox[{"n", ",", "t"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "0", ",", "10"}], "}"}]}], "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"Line", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "10"}], ",", "0"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"10", ",", "0"}], "}"}]}], "}"}], "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"jet", "[", "t", "]"}], ",", "\[IndentingNewLine]", "Dashed", 
      ",", "\[IndentingNewLine]", 
      RowBox[{"Line", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", "0"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "10"}], "}"}]}], "}"}], "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"t", ">", "10"}], ",", 
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Line", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"0.9", 
                RowBox[{"Sin", "[", "\[Theta]", "]"}], "10"}], ",", "0"}], 
              "}"}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"0.9", 
                RowBox[{"Sin", "[", "\[Theta]", "]"}], "10"}], ",", "10"}], 
              "}"}]}], "}"}], "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"Dashing", "[", "1", "]"}], ",", 
          RowBox[{"Arrowheads", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", ".05"}], ",", ".05"}], "}"}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Arrow", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", "8"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"0.9", 
                RowBox[{"Sin", "[", "\[Theta]", "]"}], "10"}], ",", "8"}], 
              "}"}]}], "}"}], "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"Text", "[", 
           RowBox[{
            RowBox[{"Style", "[", 
             RowBox[{"\"\<L\>\"", ",", "Large"}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"0.9", 
               RowBox[{"Sin", "[", "\[Theta]", "]"}], "5"}], ",", "8.5"}], 
             "}"}]}], "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"Text", "[", 
           RowBox[{
            RowBox[{"Style", "[", 
             RowBox[{
             "\"\<\!\(\*SubscriptBox[\(V\), \(1\)]\)=L/\!\(\*SubscriptBox[\(t\
\), \(1\)]\)\>\"", ",", "Large"}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"0.9", 
               RowBox[{"Sin", "[", "\[Theta]", "]"}], "10"}], ",", "11"}], 
             "}"}]}], "]"}]}], "\[IndentingNewLine]", "}"}]}], "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"Text", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Style", "[", 
         RowBox[{
          RowBox[{"\"\<\!\(\*SubscriptBox[\(t\), \(2\)]\) = \>\"", "<>", 
           RowBox[{"ToString", "[", "\[IndentingNewLine]", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"t", "<", "11.547"}], ",", "\[IndentingNewLine]", "0", 
              ",", "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"t", "<", "12.547"}], ",", "\[IndentingNewLine]", 
                RowBox[{"t", "-", "11.547"}], ",", "\[IndentingNewLine]", 
                "1"}], "]"}]}], "]"}], "\[IndentingNewLine]", "]"}]}], ",", 
          "Large"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", 
          RowBox[{"-", "1"}]}], "}"}]}], "]"}], ",", "\[IndentingNewLine]", 
      RowBox[{"Text", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Style", "[", 
         RowBox[{
          RowBox[{"\"\<\!\(\*SubscriptBox[\(t\), \(1\)]\) = \>\"", "<>", 
           RowBox[{"ToString", "[", "\[IndentingNewLine]", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"t", ">", "10"}], ",", "\[IndentingNewLine]", "10", ",",
               "\[IndentingNewLine]", "t"}], "]"}], "]"}]}], ",", 
          "\[IndentingNewLine]", "Large"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "11"}], "}"}]}], "]"}], ",", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"t", ">", "12.547"}], ",", "\[IndentingNewLine]", 
        RowBox[{"Text", "[", 
         RowBox[{
          RowBox[{"Style", "[", 
           RowBox[{
           "\"\<\!\(\*SubscriptBox[\(V\), \
\(2\)]\)=L/\!\(\*SubscriptBox[\(t\), \(2\)]\)\>\"", ",", "Large"}], "]"}], 
          ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"0.9", 
             RowBox[{"Sin", "[", "\[Theta]", "]"}], "10"}], ",", 
            RowBox[{"-", "1"}]}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
       "]"}]}], "\[IndentingNewLine]", "}"}], ",", 
    RowBox[{"PlotRange", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "2"}], ",", "7"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "2"}], ",", "12"}], "}"}]}], "}"}]}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"picture", "[", "t", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "15"}], "}"}]}], "]"}]}], "Input",

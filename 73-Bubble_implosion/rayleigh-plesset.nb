Cell[BoxData[{
 RowBox[{"Clear", "[", "\"\<Global`*\>\"", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tmax", "=", "32"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Gamma]", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"g", "=", "9.8"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"sol", "[", "d_", "]"}], ":=", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{"p", "=", 
       RowBox[{"g", "*", "d"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"NDSolve", "[", 
       RowBox[{
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"R", "''"}], "[", "t", "]"}], 
             RowBox[{"R", "[", "t", "]"}]}], "+", 
            RowBox[{"1.5", " ", 
             SuperscriptBox[
              RowBox[{
               RowBox[{"R", "'"}], "[", "t", "]"}], "2"]}], "+", "p"}], "==", 
           "0"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"R", "[", "0", "]"}], "==", "1"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"R", "'"}], "[", "0", "]"}], "==", "0"}]}], 
         "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", "R", ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", "0", ",", 
          RowBox[{"tmax", "/", "1000"}]}], "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{"WorkingPrecision", "\[Rule]", "32"}], ",", " ", 
        RowBox[{"MaxSteps", "\[Rule]", 
         SuperscriptBox["10", "4"]}]}], "\[IndentingNewLine]", "]"}], "//", 
      "Quiet"}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"depths", "=", 
   RowBox[{"{", 
    RowBox[{"0.1", ",", " ", "1", ",", "5"}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"times", "=", 

Cell[CellGroupData[{
Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "\"\<Global`*\>\"", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"a0", "=", "0.02"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tmax", "=", "6"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"s1", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"a", "''"}], "[", "t", "]"}], "==", 
        RowBox[{"Sin", "[", 
         RowBox[{"a", "[", "t", "]"}], "]"}]}], ",", 
       RowBox[{
        RowBox[{"a", "[", "0", "]"}], "==", "a0"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"a", "'"}], "[", "0", "]"}], "==", "0"}]}], "}"}], ",", "a", 
     ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "tmax"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"s2", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"a", "''"}], "[", "t", "]"}], "==", 
        RowBox[{"a", "[", "t", "]"}]}], ",", 
       RowBox[{
        RowBox[{"a", "[", "0", "]"}], "==", "a0"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"a", "'"}], "[", "0", "]"}], "==", "0"}]}], "}"}], ",", "a", 
     ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "tmax"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
  "l1", "=", 
   "\"\<\!\(\*OverscriptBox[\(\[Alpha]\), \(..\)]\) = \!\(\*SuperscriptBox[\(\
\[Omega]\), \(2\)]\)sin(\[Alpha])\>\""}], ";"}], "\n", 
 RowBox[{
  RowBox[{
  "l2", "=", 
   "\"\<\!\(\*OverscriptBox[\(\[Alpha]\), \(..\)]\) = \!\(\*SuperscriptBox[\(\
\[Omega]\), \(2\)]\)\[Alpha]\>\""}], ";"}], "\n", 
 RowBox[{
  RowBox[{"range", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "tmax"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", 
       RowBox[{
        RowBox[{"Pi", "/", "2"}], "+", "0.1"}]}], "}"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Evaluate", "[", 
        RowBox[{
         RowBox[{"a", "[", "t", "]"}], "/.", "s1"}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Evaluate", "[", 
        RowBox[{
         RowBox[{"a", "[", "t", "]"}], "/.", "s2"}], "]"}]}], 
      "\[IndentingNewLine]", "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "tmax"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"PlotRange", "->", "range"}], ",", "\[IndentingNewLine]", 
